# =================================================================
# 1. 基础网络配置 (国内访问必填)
# =================================================================
# 保障爬虫访问 x.com 及调用海外 API 端点
# 注意：端口号 (如 8118, 7890, 1080) 需根据您本地代理软件的实际设置修改
PROXY=http://127.0.0.1:7897

# =================================================================
# 2. AI 供应商降级链
# =================================================================
# 逗号分隔供应商前缀，第一个为主模型，调整顺序即改优先级
# 新增供应商只需：1. 加入此列表  2. 配置 {前缀}_API_KEY / _BASE_URL / _MODEL
AI_PROVIDER_CHAIN=GROQ,OPENROUTER,ZHIPUAI

# ── Groq ──
GROQ_API_KEY=your_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=moonshotai/kimi-k2-instruct-0905
# GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# ── OpenRouter ──
# OPENROUTER_API_KEY=sk-or-v1-xxxx
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=z-ai/glm-4.5-air:free
# OPENROUTER_FALLBACK_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# ── ZhipuAI ──
# ZHIPUAI_API_KEY=xxxx.xxxx
# ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPUAI_MODEL=glm-4.7-flash
# ZHIPUAI_FALLBACK_MODEL=glm-4-flash-250414

# ── 自定义供应商示例 ──
# 在 AI_PROVIDER_CHAIN 中追加前缀名即可，如: GROQ,OPENROUTER,ZHIPUAI,DEEPSEEK
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_NAME=DeepSeek

# =================================================================
# 3. 飞书消息推送配置
# =================================================================
FEISHU_APP_ID=cli_...
FEISHU_APP_SECRET=...
FEISHU_USER_ID=ou_...

# =================================================================
# 4. 运行参数
# =================================================================
OUTPUT_DIR=./output
LANGUAGE=zh-CN
TWEETS_PER_ACCOUNT=30
HOURS_LOOKBACK=72
CACHE_RETENTION_HOURS=720
ACCOUNT_SCAN_INTERVAL=12
AI_BATCH_SIZE=30
AI_BATCH_COOLDOWN=15
# 单批次最大条目数上限，防止 AI 输出 token 截断
# 默认 30 适配 Groq Kimi K2 (max_output=16K)
# 仅在使用输出上限更高的模型（如 32K+）时才建议调大
AI_MAX_BATCH_SIZE=30
